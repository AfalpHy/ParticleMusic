{
  "name": "ParticleMusic",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "start-win": "chcp 65001 && electron . --enable-logging",
    "build-linux": "electron-builder --linux --x64",
    "build-windows": "electron-builder --win --x64",
    "dev": "nodemon --watch . --ext js,html,css --exec 'electron . --enable-logging'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "a freedom music player",
  "dependencies": {
    "chokidar": "^4.0.3",
    "file-type": "^21.0.0",
    "get-image-colors": "^4.0.1",
    "music-metadata": "^11.7.0"
  },
  "devDependencies": {
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "nodemon": "^3.1.10"
  },
  "build": {
    "appId": "me.username.ParticleMusic",
    "productName": "ParticleMusic",
    "icon": "pictures/icon.png",
    "linux": {
      "target": "dir",
      "category": "AudioVideo",
      "executableName": "ParticleMusic"
    },
    "win": {
      "target": "dir"
    }
  }
}